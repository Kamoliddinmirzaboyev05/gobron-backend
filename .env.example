# App 
PORT=3000 
NODE_ENV=development 

# Database
# Supabase misol: postgresql://postgres:your_password@db.your-project-ref.supabase.co:5432/postgres
# Local misol:    postgresql://postgres:postgres@localhost:5432/gobron
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/gobron"

# Supabase
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_ANON_KEY="your-anon-key" 
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key" 

# JWT 
JWT_SECRET="your-super-secret-jwt-key-min-32-chars" 
JWT_EXPIRES_IN="7d" 
JWT_REFRESH_EXPIRES_IN="30d" 

# Telegram Bot 
TELEGRAM_BOT_TOKEN="your-telegram-bot-token" 
SUPERADMIN_TELEGRAM_ID="123456789"
