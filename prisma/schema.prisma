generator client { 
 provider = "prisma-client-js" 
 } 
 
 datasource db { 
 provider = "postgresql" 
 url      = env("DATABASE_URL")
 } 
 
 enum Role { 
 user 
 admin 
 superadmin 
 } 
 
 enum BookingStatus { 
 pending 
 confirmed 
 rejected 
 cancelled 
 completed 
 } 
 
 enum PaymentMethod { 
 cash 
 click 
 payme 
 } 
 
 enum SubscriptionPlan { 
 basic 
 pro 
 unlimited 
 } 
 
 enum NotificationType { 
 booking_pending 
 booking_confirmed 
 booking_rejected 
 booking_cancelled 
 subscription_expiry 
 } 
 
 model User { 
 id String @id @default(uuid()) 
 fullName String @map("full_name") 
 login String @unique 
 password String 
 role Role @default(user) 
 createdAt DateTime @default(now()) @map("created_at") 
 
 field Field? 
 bookings Booking[] 
 notifications Notification[] 
 
 @@map("users") 
 } 
 
 model Field { 
 id String @id @default(uuid()) 
 userId String @unique @map("user_id") 
 name String @default("") 
 address String @default("") 
 city String @default("Toshkent") 
 lat Float? 
 lng Float? 
 pricePerHour Int @default(0) @map("price_per_hour") 
 size String? 
 surface String? 
 description String? 
 amenities String[] 
 images String[] 
 openTime String @default("08:00") @map("open_time") 
 closeTime String @default("23:00") @map("close_time") 
 phone String? 
 isActive Boolean @default(false) @map("is_active") 
 createdAt DateTime @default(now()) @map("created_at") 
 
 user User @relation(fields: [userId], references: [id], onDelete: Cascade) 
 timeSlots TimeSlot[] 
 bookings Booking[] 
 subscriptions Subscription[] 
 
 @@map("fields") 
 } 
 
 model TimeSlot { 
 id String @id @default(uuid()) 
 fieldId String @map("field_id") 
 slotDate DateTime @map("slot_date") @db.Date 
 startTime String @map("start_time") 
 endTime String @map("end_time") 
 isAvailable Boolean  @default(true) @map("is_available") 
 
 field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade) 
 
 @@unique([fieldId, slotDate, startTime]) 
 @@map("time_slots") 
 } 
 
 model Booking { 
 id String @id @default(uuid()) 
 userId String @map("user_id") 
 fieldId String @map("field_id") 
 bookingDate DateTime @map("booking_date") @db.Date 
 startTime String @map("start_time") 
 endTime String @map("end_time") 
 totalPrice Int @map("total_price") 
 status BookingStatus @default(pending) 
 paymentMethod PaymentMethod @default(cash) @map("payment_method") 
 note String? 
 createdAt DateTime @default(now()) @map("created_at") 
 confirmedAt DateTime? @map("confirmed_at") 
 rejectedAt DateTime? @map("rejected_at") 
 rejectReason String? @map("reject_reason") 
 
 user User @relation(fields: [userId], references: [id]) 
 field Field @relation(fields: [fieldId], references: [id]) 
 notifications Notification[] 
 
 @@map("bookings") 
 } 
 
 model Subscription { 
 id String @id @default(uuid()) 
 fieldId String @map("field_id") 
 plan SubscriptionPlan @default(basic) 
 startsAt DateTime @default(now()) @map("starts_at") 
 expiresAt DateTime @map("expires_at") 
 isActive Boolean @default(true) @map("is_active") 
 createdAt DateTime @default(now()) @map("created_at") 
 
 field Field @relation(fields: [fieldId], references: [id], onDelete: Cascade) 
 
 @@map("subscriptions") 
 } 
 
 model Notification { 
 id String @id @default(uuid()) 
 userId String @map("user_id") 
 bookingId String? @map("booking_id") 
 type NotificationType 
 title String 
 message String 
 isRead Boolean @default(false) @map("is_read") 
 createdAt DateTime @default(now()) @map("created_at") 
 
 user User @relation(fields: [userId], references: [id], onDelete: Cascade) 
 booking Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull) 
 
 @@map("notifications") 
 } 
